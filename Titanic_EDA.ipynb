# ==========================================
# TITANIC DATASET - EXPLORATORY DATA ANALYSIS
# ==========================================

import pandas as pd
import numpy as np

# Load Titanic Dataset
url = "https://raw.githubusercontent.com/datasciencedojo/datasets/master/titanic.csv"
df = pd.read_csv(url)

# ==========================================
# 1. First 5 Rows
# ==========================================
print("\nFIRST 5 ROWS")
print(df.head())

# ==========================================
# 2. Dataset Shape
# ==========================================
print("\nDATASET SHAPE")
print(df.shape)

# ==========================================
# 3. Column Names
# ==========================================
print("\nCOLUMN NAMES")
print(df.columns.tolist())

# ==========================================
# 4. Dataset Information
# ==========================================
print("\nDATASET INFO")
df.info()

# ==========================================
# 5. Data Types
# ==========================================
print("\nDATA TYPES")
print(df.dtypes)

# ==========================================
# 6. Statistical Summary
# ==========================================
print("\nSTATISTICAL SUMMARY")
print(df.describe())

# ==========================================
# 7. Missing Values
# ==========================================
print("\nMISSING VALUES")
print(df.isnull().sum())

# ==========================================
# 8. Numerical Columns
# ==========================================
numerical_columns = df.select_dtypes(
    include=['int64', 'float64']
).columns

print("\nNUMERICAL COLUMNS")
print(list(numerical_columns))

# ==========================================
# 9. Categorical Columns
# ==========================================
categorical_columns = df.select_dtypes(
    include=['object']
).columns

print("\nCATEGORICAL COLUMNS")
print(list(categorical_columns))

# ==========================================
# 10. Unique Values in Categorical Columns
# ==========================================
print("\nUNIQUE VALUES IN CATEGORICAL COLUMNS")

for col in categorical_columns:
    print(f"\nColumn: {col}")
    print("Unique Count:", df[col].nunique())
    print(df[col].unique())

# ==========================================
# 11. Duplicate Rows
# ==========================================
duplicates = df.duplicated().sum()

print("\nDUPLICATE ROWS")
print(duplicates)

# ==========================================
# 12. Survival Distribution
# ==========================================
print("\nSURVIVAL DISTRIBUTION")
print(df['Survived'].value_counts())

# ==========================================
# 13. Gender Distribution
# ==========================================
print("\nGENDER DISTRIBUTION")
print(df['Sex'].value_counts())

# ==========================================
# 14. Passenger Class Distribution
# ==========================================
print("\nPASSENGER CLASS DISTRIBUTION")
print(df['Pclass'].value_counts())

# ==========================================
# 15. Correlation Matrix
# ==========================================
print("\nCORRELATION MATRIX")
print(df.corr(numeric_only=True))

# ==========================================
# 16. Final Summary
# ==========================================
print("\n====================================")
print("FINAL DATASET SUMMARY")
print("====================================")

print(f"Total Rows: {df.shape[0]}")
print(f"Total Columns: {df.shape[1]}")
print(f"Numerical Features: {len(numerical_columns)}")
print(f"Categorical Features: {len(categorical_columns)}")
print(f"Total Missing Values: {df.isnull().sum().sum()}")
print(f"Duplicate Rows: {duplicates}")

print("\nEDA COMPLETED SUCCESSFULLY")
